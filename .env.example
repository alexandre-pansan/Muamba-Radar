# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/mamu

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-random-secret
JWT_EXPIRE_MINUTES=10080

# ── CORS ───────────────────────────────────────────────────────────────────────
# In production, set to your actual frontend domain (e.g. https://muambaradar.com)
CORS_ORIGINS=*

# ── FX rates ───────────────────────────────────────────────────────────────────
FX_PYG_PER_BRL=1428.57
FX_BRL_PER_USD=5.0

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_TTL_MINUTES=30

# ── Frontend API URL ───────────────────────────────────────────────────────────
MUAMBA_API_URL=

# ── Admin inicial (só usado no primeiro boot, se não existir admin) ───────────
# Deixe em branco para pular o seed automático
ADMIN_EMAIL=
ADMIN_PASSWORD=
