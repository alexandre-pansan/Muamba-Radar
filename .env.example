# ── Database ───────────────────────────────────────────────────────────────────
# Required. Use a strong random password on production.
POSTGRES_PASSWORD=change-me

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
# Required. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080

# ── CORS ───────────────────────────────────────────────────────────────────────
# Production: set to your domain, e.g. https://mamu.example.com
# Dev: leave as *
CORS_ORIGINS=*

# ── FX rates ───────────────────────────────────────────────────────────────────
FX_PYG_PER_BRL=1428.57
FX_BRL_PER_USD=5.0

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_TTL_MINUTES=30

# ── Frontend API URL ───────────────────────────────────────────────────────────
# Leave empty when frontend and API are on the same server (nginx proxies internally).
# Set to a full URL only if the API is on a different domain.
MUAMBA_API_URL=
