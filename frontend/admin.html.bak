<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MuambaRadar Dev Tools</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0d0d0d;
      color: #e0e0e0;
      font-family: 'Segoe UI', system-ui, sans-serif;
      font-size: 14px;
      min-height: 100vh;
    }

    header {
      background: #111;
      border-bottom: 1px solid #2a2a2a;
      padding: 12px 20px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    header h1 { font-size: 18px; color: #fff; }
    header .badge {
      background: #c00;
      color: #fff;
      font-size: 10px;
      font-weight: bold;
      padding: 2px 6px;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    header .spacer { flex: 1; }
    header .user-info { color: #888; font-size: 13px; }
    header a { color: #5a9cf8; text-decoration: none; font-size: 13px; }
    header a:hover { text-decoration: underline; }

    #accessDenied {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 80vh;
      gap: 12px;
      text-align: center;
    }
    #accessDenied h2 { color: #e55; font-size: 24px; }
    #accessDenied p { color: #888; }

    #loadingMsg {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 80vh;
      color: #666;
    }

    main {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 0;
      height: calc(100vh - 53px);
    }

    /* ── Left panel ── */
    .left-panel {
      background: #111;
      border-right: 1px solid #2a2a2a;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .panel-section {
      padding: 16px;
      border-bottom: 1px solid #1e1e1e;
    }
    .panel-section h3 {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #555;
      margin-bottom: 10px;
    }

    #testQuery {
      width: 100%;
      background: #1a1a1a;
      border: 1px solid #333;
      color: #e0e0e0;
      padding: 8px 10px;
      border-radius: 6px;
      font-size: 14px;
      margin-bottom: 8px;
    }
    #testQuery:focus { outline: none; border-color: #5a9cf8; }

    #runBtn {
      width: 100%;
      background: #5a9cf8;
      color: #fff;
      border: none;
      padding: 9px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    #runBtn:hover:not(:disabled) { background: #3d7fd4; }
    #runBtn:disabled { opacity: 0.5; cursor: default; }

    .adapter-controls {
      display: flex;
      gap: 8px;
      margin-bottom: 10px;
    }
    .adapter-controls button {
      flex: 1;
      background: #1e1e1e;
      border: 1px solid #333;
      color: #aaa;
      padding: 5px;
      border-radius: 5px;
      font-size: 12px;
      cursor: pointer;
    }
    .adapter-controls button:hover { background: #2a2a2a; color: #e0e0e0; }

    .adapter-list { overflow-y: auto; flex: 1; padding: 8px 16px; }

    .adapter-group-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #444;
      margin: 10px 0 6px;
    }
    .adapter-check {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 6px;
      border-radius: 5px;
      cursor: pointer;
    }
    .adapter-check:hover { background: #1a1a1a; }
    .adapter-check input[type=checkbox] { accent-color: #5a9cf8; }
    .adapter-check .name { color: #ccc; font-size: 13px; }
    .adapter-check .country {
      margin-left: auto;
      font-size: 11px;
      padding: 1px 6px;
      border-radius: 10px;
      font-weight: 600;
    }
    .country-br { background: #1a3a1a; color: #4caf50; }
    .country-py { background: #1a2a3a; color: #5a9cf8; }

    /* ── Right panel ── */
    .right-panel {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .results-header {
      padding: 16px 20px;
      border-bottom: 1px solid #1e1e1e;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .results-header h3 { font-size: 13px; font-weight: 600; color: #888; }
    .results-header .summary-stat {
      background: #1a1a1a;
      border: 1px solid #2a2a2a;
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 12px;
      color: #aaa;
    }
    .results-header .summary-stat strong { color: #e0e0e0; }

    .results-body {
      flex: 1;
      overflow-y: auto;
      padding: 16px 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .empty-state {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: #333;
      font-size: 16px;
    }

    .adapter-card {
      background: #111;
      border: 1px solid #222;
      border-radius: 8px;
      overflow: hidden;
    }
    .adapter-card.has-error { border-color: #5a1a1a; }
    .adapter-card.has-results { border-color: #1a3a1a; }

    .adapter-card-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      background: #151515;
      border-bottom: 1px solid #1e1e1e;
    }
    .adapter-card-header .adapter-name {
      font-weight: 600;
      font-size: 14px;
      color: #e0e0e0;
    }
    .adapter-card-header .country-pill {
      font-size: 11px;
      padding: 1px 7px;
      border-radius: 10px;
      font-weight: 600;
    }
    .adapter-card-header .timing {
      margin-left: auto;
      font-size: 12px;
      color: #555;
    }
    .timing.slow { color: #e5a244; }
    .timing.very-slow { color: #e55; }

    .adapter-card-body { padding: 10px 14px; }

    .counts {
      display: flex;
      gap: 12px;
      margin-bottom: 8px;
    }
    .count-chip {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      color: #777;
    }
    .count-chip strong { font-size: 15px; color: #aaa; }
    .count-chip.filtered strong { color: #4caf50; }

    .error-box {
      background: #1a0a0a;
      border: 1px solid #5a1a1a;
      border-radius: 5px;
      padding: 8px 10px;
      font-family: monospace;
      font-size: 12px;
      color: #e55;
      word-break: break-all;
      margin-bottom: 8px;
    }

    .offers-list { display: flex; flex-direction: column; gap: 4px; }
    .offer-row {
      display: flex;
      align-items: baseline;
      gap: 10px;
      padding: 5px 8px;
      background: #0d0d0d;
      border-radius: 5px;
      font-size: 12px;
    }
    .offer-row .offer-title {
      flex: 1;
      color: #bbb;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .offer-row .offer-price {
      white-space: nowrap;
      font-weight: 600;
      color: #4caf50;
    }
    .offer-row a {
      color: #5a9cf8;
      text-decoration: none;
      font-size: 11px;
      white-space: nowrap;
    }
    .offer-row a:hover { text-decoration: underline; }

    .no-results-msg { color: #444; font-size: 13px; font-style: italic; }

    /* scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #2a2a2a; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #3a3a3a; }
  </style>
</head>
<body>

<div id="loadingMsg">Loading…</div>

<div id="accessDenied" hidden>
  <h2>Access Denied</h2>
  <p>This page requires an admin account.</p>
  <br>
  <a href="/">← Back to MAMU</a>
</div>

<div id="devApp" hidden>
  <header>
    <h1>MuambaRadar Dev Tools</h1>
    <span class="badge">Admin</span>
    <span class="spacer"></span>
    <span class="user-info" id="adminUserLabel"></span>
    <a href="/">← App</a>
  </header>

  <main>
    <!-- Left panel -->
    <div class="left-panel">
      <div class="panel-section">
        <h3>Test Search</h3>
        <input id="testQuery" type="text" placeholder="e.g. iphone 15 128gb">
        <button id="runBtn">Run Search</button>
      </div>
      <div class="panel-section">
        <h3>Adapters</h3>
        <div class="adapter-controls">
          <button id="selectAll">Select All</button>
          <button id="selectNone">Deselect All</button>
        </div>
      </div>
      <div class="adapter-list" id="adapterList"></div>
    </div>

    <!-- Right panel -->
    <div class="right-panel">
      <div class="results-header">
        <h3>Results</h3>
        <div class="summary-stat" id="statRaw" hidden>Raw: <strong id="totalRaw">0</strong></div>
        <div class="summary-stat" id="statFiltered" hidden>Filtered: <strong id="totalFiltered">0</strong></div>
      </div>
      <div class="results-body" id="resultsBody">
        <div class="empty-state">Run a search to see per-adapter debug output</div>
      </div>
    </div>
  </main>
</div>

<script src="config.js"></script>
<script>
  function apiBase() {
    return (typeof window.__MUAMBA_API__ === "string" && window.__MUAMBA_API__)
      ? window.__MUAMBA_API__.replace(/\/+$/, "")
      : "http://localhost:8000";
  }

  function getToken() { return localStorage.getItem("muamba_token"); }

  async function init() {
    const token = getToken();
    if (!token) { showDenied(); return; }

    let user;
    try {
      const res = await fetch(`${apiBase()}/auth/me`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) { showDenied(); return; }
      user = await res.json();
    } catch { showDenied(); return; }

    if (!user.is_admin) { showDenied(); return; }

    document.getElementById("adminUserLabel").textContent = user.name || user.email;
    document.getElementById("loadingMsg").hidden = true;
    document.getElementById("devApp").hidden = false;

    await loadAdapters();
    setupEvents();
  }

  function showDenied() {
    document.getElementById("loadingMsg").hidden = true;
    document.getElementById("accessDenied").hidden = false;
  }

  let adapters = [];

  async function loadAdapters() {
    try {
      const res = await fetch(`${apiBase()}/sources`);
      adapters = await res.json();
    } catch { adapters = []; }

    const list = document.getElementById("adapterList");
    list.innerHTML = "";

    const byCountry = { br: [], py: [] };
    adapters.forEach(a => (byCountry[a.country] || []).push(a));

    for (const [country, group] of Object.entries(byCountry)) {
      if (!group.length) continue;
      const label = document.createElement("div");
      label.className = "adapter-group-label";
      label.textContent = country === "br" ? "Brasil" : "Paraguai";
      list.appendChild(label);

      group.forEach(a => {
        const wrap = document.createElement("label");
        wrap.className = "adapter-check";
        wrap.innerHTML = `
          <input type="checkbox" class="adapter-cb" value="${a.source}" checked>
          <span class="name">${a.source}</span>
          <span class="country-pill country-${a.country}">${a.country.toUpperCase()}</span>`;
        list.appendChild(wrap);
      });
    }
  }

  function setupEvents() {
    document.getElementById("selectAll").addEventListener("click", () => {
      document.querySelectorAll(".adapter-cb").forEach(cb => cb.checked = true);
    });
    document.getElementById("selectNone").addEventListener("click", () => {
      document.querySelectorAll(".adapter-cb").forEach(cb => cb.checked = false);
    });
    document.getElementById("runBtn").addEventListener("click", runSearch);
    document.getElementById("testQuery").addEventListener("keydown", e => {
      if (e.key === "Enter") runSearch();
    });
  }

  async function runSearch() {
    const query = document.getElementById("testQuery").value.trim();
    if (!query) return;

    const selected = [...document.querySelectorAll(".adapter-cb:checked")].map(cb => cb.value);
    const runBtn = document.getElementById("runBtn");
    runBtn.disabled = true;
    runBtn.textContent = "Running…";

    const body = { query, adapter_ids: selected };

    try {
      const res = await fetch(`${apiBase()}/admin/test-search`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${getToken()}`,
        },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        renderError(`HTTP ${res.status}: ${await res.text()}`);
        return;
      }

      const data = await res.json();
      renderResults(data);
    } catch (err) {
      renderError(String(err));
    } finally {
      runBtn.disabled = false;
      runBtn.textContent = "Run Search";
    }
  }

  function renderResults(data) {
    document.getElementById("statRaw").hidden = false;
    document.getElementById("statFiltered").hidden = false;
    document.getElementById("totalRaw").textContent = data.total_raw;
    document.getElementById("totalFiltered").textContent = data.total_filtered;

    const body = document.getElementById("resultsBody");
    body.innerHTML = "";

    // Sort: errors first, then by filtered_count desc
    const sorted = [...data.adapters].sort((a, b) => {
      if (a.error && !b.error) return -1;
      if (!a.error && b.error) return 1;
      return b.filtered_count - a.filtered_count;
    });

    sorted.forEach(a => {
      const card = document.createElement("div");
      card.className = "adapter-card" +
        (a.error ? " has-error" : a.filtered_count > 0 ? " has-results" : "");

      const timingClass = a.timing_ms > 5000 ? "very-slow" : a.timing_ms > 2000 ? "slow" : "";

      let offersHtml = "";
      if (a.sample_offers.length > 0) {
        offersHtml = `<div class="offers-list">` +
          a.sample_offers.map(o => `
            <div class="offer-row">
              <span class="offer-title" title="${escHtml(o.title)}">${escHtml(o.title)}</span>
              <span class="offer-price">${o.currency} ${o.price.toLocaleString("pt-BR", {minimumFractionDigits: 2})}</span>
              <a href="${escHtml(o.url)}" target="_blank">↗</a>
            </div>`).join("") +
          `</div>`;
      } else if (!a.error) {
        offersHtml = `<p class="no-results-msg">No results passed the filter.</p>`;
      }

      card.innerHTML = `
        <div class="adapter-card-header">
          <span class="adapter-name">${a.adapter_id}</span>
          <span class="country-pill country-${a.country}">${a.country.toUpperCase()}</span>
          <span class="timing ${timingClass}">${a.timing_ms}ms</span>
        </div>
        <div class="adapter-card-body">
          <div class="counts">
            <span class="count-chip">Raw <strong>${a.raw_count}</strong></span>
            <span class="count-chip filtered">Filtered <strong>${a.filtered_count}</strong></span>
          </div>
          ${a.error ? `<div class="error-box">${escHtml(a.error)}</div>` : ""}
          ${offersHtml}
        </div>`;

      body.appendChild(card);
    });
  }

  function renderError(msg) {
    document.getElementById("resultsBody").innerHTML =
      `<div class="error-box" style="margin:0">${escHtml(msg)}</div>`;
  }

  function escHtml(s) {
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  init();
</script>
</body>
</html>
